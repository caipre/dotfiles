alias diff='diff -s'
alias ll='ls -lahF --group-directories-first --time-style long-iso --color'
alias l=ll
alias mkdir='mkdir -p'
alias sun='sort | uniq -c | sort -rn'
alias vi=vim

# git
alias br='git branch'
alias co='git checkout --recurse-submodules'
alias di='git diff'
alias lg='git lg -n10'
alias st='git status'
